{
  "name": "gallery_project",
  "version": "1.0.0",
  "repository": "git@github.com:shalbuz-cloud/gallery_project.git",
  "author": "shalbuz <sh.mursalov@mail.ru>",
  "license": "MIT",
  "scripts": {
    "sass-dev": "sass assets/scss:static/css --source-map --watch",
    "sass-min": "sass assets/scss:static/css --style=compressed --source-map --watch",

    "js-dev": "terser assets/js/main.js -o static/js/main.js --source-map --watch",
    "js-min": "terser assets/js/main.js -o static/js/main.min.js --compress --mangle --source-map --watch",
    "watch": "npm-run-all --parallel sass-* js-*",
    "build": "npm run sass-min && npm run js-min"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "sass": "^1.97.3",
    "terser": "^5.46.0"
  }
}
